# ============================================================
# Konfigurasi untuk deploy ke Sepolia Testnet (Bonus)
# Salin file ini menjadi .env lalu isi nilainya.
# JANGAN commit file .env yang berisi private key asli.
# ============================================================

# RPC endpoint Sepolia. Bisa dari Alchemy/Infura, atau RPC publik default.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key wallet untuk deploy (gunakan akun testing, BUKAN akun utama).
# Ambil dari MetaMask: Account Details -> Show private key.
PRIVATE_KEY=

# (Opsional) API key Etherscan untuk verifikasi kontrak.
ETHERSCAN_API_KEY=
